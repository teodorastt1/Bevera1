@model List<Bevera.Models.Catalog.Product>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Промоции";
    var q = ViewBag.Q as string ?? "";
}

<div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
    <div>
        <h1 class="mb-1">Промоции</h1>
        <div class="text-muted small">Избери продукт и добави или редактирай промоция.</div>
    </div>
</div>

<form method="get" class="card card-body shadow-sm mb-3">
    <div class="row g-2 align-items-end">
        <div class="col-md-6">
            <label class="form-label mb-1">Търсене</label>
            <input name="q" value="@q" class="form-control" placeholder="Име на продукт..." />
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button class="btn btn-primary w-100" type="submit">Търси</button>
            <a class="btn btn-outline-secondary w-100" asp-action="Index">Изчисти</a>
        </div>
    </div>
</form>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th style="width:80px;">Снимка</th>
                    <th>Продукт</th>
                    <th>Категория</th>
                    <th>Цена</th>
                    <th>Промоция</th>
                    <th>Край</th>
                    <th class="text-end" style="width:180px;">Действия</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">Няма продукти.</td>
                    </tr>
                }
                else
                {
                    foreach (var p in Model)
                    {
                        var img = p.Images.OrderByDescending(i => i.IsMain).Select(i => i.ImagePath).FirstOrDefault();
                        var activePromo = p.DiscountPercent.HasValue && p.DiscountPercent.Value > 0
                            && (!p.DiscountEndsAt.HasValue || p.DiscountEndsAt.Value >= DateTime.UtcNow);

                        <tr>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(img))
                                {
                                    <img src="@img" style="width:60px;height:60px;object-fit:cover;border-radius:10px;" />
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td class="fw-semibold">@p.Name</td>
                            <td>@p.Category?.Name</td>
                            <td>@p.Price.ToString("0.00") €</td>
                            <td>
                                @if (activePromo)
                                {
                                    <span class="badge bg-danger">-@p.DiscountPercent?.ToString("0")%</span>
                                }
                                else
                                {
                                    <span class="text-muted">Няма</span>
                                }
                            </td>
                            <td>
                                @(p.DiscountEndsAt.HasValue? p.DiscountEndsAt.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm") : "-")
                            </td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-danger"
                                       asp-action="Edit"
                                       asp-route-id="@p.Id">
                                    Управлявай
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>