@using Bevera.Helpers
@using Bevera.Models.ViewModels
@model PagedResult<Bevera.Models.Order>

@{
    ViewData["Title"] = "Поръчки";

    var status = (string?)ViewBag.Status;
    var q = (string?)ViewBag.Q;
    var name = (string?)ViewBag.Name;
    var email = (string?)ViewBag.Email;
    DateTime? from = ViewBag.From as DateTime?;
    DateTime? to = ViewBag.To as DateTime?;
    var payment = (string?)ViewBag.Payment;
    var sort = (string?)ViewBag.Sort;
    var pageSize = (int)(ViewBag.PageSize ?? 10);
}

<div class="container-fluid p-3">

    <!-- ================= ФИЛТРИ ================= -->
    <div class="card mb-3">
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">

                <div class="col-md-2">
                    <label class="form-label">Статус</label>
                    <select class="form-select" name="status">
                        <option value="">Всички</option>
                        <option value="@OrderStates.Draft" selected="@(status == OrderStates.Draft)">Чернова</option>
                        <option value="@OrderStates.Submitted" selected="@(status == OrderStates.Submitted)">Подадена</option>
                        <option value="@OrderStates.Preparing" selected="@(status == OrderStates.Preparing)">Подготовка</option>
                        <option value="@OrderStates.ReadyForPickup" selected="@(status == OrderStates.ReadyForPickup)">Готова за изпращане</option>
                        <option value="@OrderStates.Delivered" selected="@(status == OrderStates.Delivered)">Доставена</option>
                        <option value="@OrderStates.Received" selected="@(status == OrderStates.Received)">Получена</option>
                        <option value="@OrderStates.Cancelled" selected="@(status == OrderStates.Cancelled)">Отказана</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">Търсене</label>
                    <input class="form-control" type="text" name="q" value="@q" placeholder="№ или текст..." />
                </div>

                <div class="col-md-2">
                    <label class="form-label">Име</label>
                    <input class="form-control" type="text" name="name" value="@name" />
                </div>

                <div class="col-md-2">
                    <label class="form-label">Имейл</label>
                    <input class="form-control" type="text" name="email" value="@email" />
                </div>

                <div class="col-md-2">
                    <label class="form-label">От дата</label>
                    <input class="form-control" type="date" name="from"
                           value="@(from.HasValue? from.Value.ToString("yyyy-MM-dd") : "")" />
                </div>

                <div class="col-md-2">
                    <label class="form-label">До дата</label>
                    <input class="form-control" type="date" name="to"
                           value="@(to.HasValue? to.Value.ToString("yyyy-MM-dd") : "")" />
                </div>

                <div class="col-md-2">
                    <label class="form-label">Плащане</label>
                    <select class="form-select" name="payment">
                        <option value="">Всички</option>
                        <option value="@PaymentStates.Paid" selected="@(payment == PaymentStates.Paid)">Платена</option>
                        <option value="@PaymentStates.Unpaid" selected="@(payment == PaymentStates.Unpaid)">Неплатена</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">Сортиране</label>
                    <select class="form-select" name="sort">
                        <option value="changed_desc" selected="@(sort == null || sort == "changed_desc")">Последна промяна ↓</option>
                        <option value="changed_asc" selected="@(sort == "changed_asc")">Последна промяна ↑</option>
                        <option value="total_desc" selected="@(sort == "total_desc")">Сума ↓</option>
                        <option value="total_asc" selected="@(sort == "total_asc")">Сума ↑</option>
                        <option value="id_desc" selected="@(sort == "id_desc")">№ ↓</option>
                        <option value="id_asc" selected="@(sort == "id_asc")">№ ↑</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">На страница</label>
                    <select class="form-select" name="pageSize">
                        <option value="5" selected="@(pageSize == 5)">5</option>
                        <option value="10" selected="@(pageSize == 10)">10</option>
                        <option value="20" selected="@(pageSize == 20)">20</option>
                        <option value="50" selected="@(pageSize == 50)">50</option>
                    </select>
                </div>

                <div class="col-md-2 d-grid">
                    <button class="btn btn-primary">
                        <i class="bi bi-funnel"></i> Филтрирай
                    </button>
                </div>

                <div class="col-md-2 d-grid">
                    <a class="btn btn-outline-secondary" asp-action="Index">
                        Изчисти
                    </a>
                </div>

            </form>
        </div>
    </div>

    <!-- ================= ТАБЛИЦА ================= -->
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>№</th>
                        <th>Клиент</th>
                        <th>Статус</th>
                        <th>Плащане</th>
                        <th>Общо</th>
                        <th>Обновено</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in Model.Items)
                    {
                        <tr>
                            <td class="fw-bold">@o.Id</td>
                            <td>
                                <div class="fw-semibold">@(o.Client?.Email ?? o.Email)</div>
                                <div class="text-muted small">@o.FullName</div>
                            </td>
                            <td>
                                <span class="badge bg-secondary">@o.Status</span>
                            </td>
                            <td>
                                <span class="badge @(o.PaymentStatus == PaymentStates.Paid ? "bg-success" : "bg-warning text-dark")">
                                    @o.PaymentStatus
                                </span>
                            </td>
                            <td>@o.Total.ToString("0.00") €</td>
                            <td>@o.ChangedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                            <td class="text-end">
                                <div class="d-inline-flex gap-2">
                                    <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@o.Id">
                                        <i class="bi bi-eye"></i> Детайли
                                    </a>
                                    <a class="btn btn-sm btn-outline-secondary" asp-action="DownloadInvoice" asp-route-id="@o.Id">
                                        <i class="bi bi-file-earmark-pdf"></i> Фактура
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- ================= ПАГИНАЦИЯ ================= -->
    <div class="d-flex justify-content-between align-items-center mt-3">
        <div class="text-muted">
            Страница @Model.Page / @Model.TotalPages • Общо: @Model.TotalItems
        </div>

        <div class="btn-group">
            <a class="btn btn-outline-secondary @(Model.HasPrevious ? "" : "disabled")"
               asp-action="Index"
               asp-route-status="@status"
               asp-route-q="@q"
               asp-route-name="@name"
               asp-route-email="@email"
               asp-route-from="@(from?.ToString("yyyy-MM-dd"))"
               asp-route-to="@(to?.ToString("yyyy-MM-dd"))"
               asp-route-payment="@payment"
               asp-route-sort="@sort"
               asp-route-page="@(Model.Page - 1)"
               asp-route-pageSize="@pageSize">Предишна</a>

            <a class="btn btn-outline-secondary @(Model.HasNext ? "" : "disabled")"
               asp-action="Index"
               asp-route-status="@status"
               asp-route-q="@q"
               asp-route-name="@name"
               asp-route-email="@email"
               asp-route-from="@(from?.ToString("yyyy-MM-dd"))"
               asp-route-to="@(to?.ToString("yyyy-MM-dd"))"
               asp-route-payment="@payment"
               asp-route-sort="@sort"
               asp-route-page="@(Model.Page + 1)"
               asp-route-pageSize="@pageSize">Следваща</a>
        </div>
    </div>

</div>