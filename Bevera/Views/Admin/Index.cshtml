@model Bevera.Models.ViewModel.AdminDashboardViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Табло";
}

<div class="kpi-grid">

    <div class="kpi-card kpi--blue">
        <div class="kpi-head">
            <div>
                <div class="kpi-label">Категории</div>
                <div class="kpi-value">@Model.CategoriesCount</div>
            </div>
            <div class="kpi-icon">
                <img src="~/images/icons/category.png" alt="Категории" />
            </div>
        </div>
        <div class="kpi-footer">
            <a class="kpi-link" asp-controller="AdminCategories" asp-action="Index">
                <span class="eye">👁️</span> Преглед
            </a>
        </div>
    </div>

    <div class="kpi-card kpi--rose">
        <div class="kpi-head">
            <div>
                <div class="kpi-label">Продукти</div>
                <div class="kpi-value">@Model.ProductsCount</div>
            </div>
            <div class="kpi-icon">
                <img src="~/images/icons/products.png" alt="Продукти" />
            </div>
        </div>
        <div class="kpi-footer">
            <a class="kpi-link" asp-controller="AdminProducts" asp-action="Index">
                <span class="eye">👁️</span> Преглед
            </a>
        </div>
    </div>

    <div class="kpi-card kpi--dark">
        <div class="kpi-head">
            <div>
                <div class="kpi-label">Общо поръчки</div>
                <div class="kpi-value">@Model.OrdersCount</div>
            </div>
            <div class="kpi-icon">
                <img src="~/images/icons/orders.png" alt="Поръчки" />
            </div>
        </div>
        <div class="kpi-footer">
            <a class="kpi-link" asp-controller="Orders" asp-action="Index">
                <span class="eye">👁️</span> Преглед
            </a>
        </div>
    </div>

    <div class="kpi-card kpi--red">
        <div class="kpi-head">
            <div>
                <div class="kpi-label">Приходи</div>
                <div class="kpi-value">@Model.Revenue.ToString("0.00") €</div>
            </div>
            <div class="kpi-icon">
                <img src="~/images/icons/revenue.jpg" alt="Приходи" />
            </div>
        </div>
        <div class="kpi-footer"></div>
    </div>

    <div class="kpi-card kpi--rose">
        <div class="kpi-head">
            <div>
                <div class="kpi-label">Чакащи</div>
                <div class="kpi-value">@Model.PendingOrders</div>
            </div>
            <div class="kpi-icon">
                <img src="~/images/icons/pending.png" alt="Чакащи" />
            </div>
        </div>
        <div class="kpi-footer">
            <a class="kpi-link" asp-controller="Orders" asp-action="Index" asp-route-status="Submitted">
                <span class="eye">👁️</span> Преглед
            </a>
        </div>
    </div>

    <div class="kpi-card kpi--blue">
        <div class="kpi-head">
            <div>
                <div class="kpi-label">Доставени</div>
                <div class="kpi-value">@Model.DeliveredOrders</div>
            </div>
            <div class="kpi-icon">
                <img src="~/images/icons/delivered.png" alt="Доставени" />
            </div>
        </div>
        <div class="kpi-footer">
            <a class="kpi-link" asp-controller="Orders" asp-action="Index" asp-route-status="Delivered">
                <span class="eye">👁️</span> Преглед
            </a>
        </div>
    </div>

    <div class="kpi-card kpi--red">
        <div class="kpi-head">
            <div>
                <div class="kpi-label">Ниска наличност</div>
                <div class="kpi-value">@Model.LowStockProducts</div>
            </div>
            <div class="kpi-icon">
                <img src="~/images/icons/lowstock.jpg" alt="Ниска наличност" />
            </div>
        </div>
        <div class="kpi-footer">
            <a class="kpi-link" asp-controller="AdminProducts" asp-action="Index" asp-route-stock="low">
                <span class="eye">👁️</span> Преглед
            </a>
        </div>
    </div>

    <div class="kpi-card kpi--dark">
        <div class="kpi-head">
            <div>
                <div class="kpi-label">Потребители</div>
                <div class="kpi-value">@Model.UsersCount</div>
            </div>
            <div class="kpi-icon">
                <img src="~/images/icons/user.jpg" alt="Потребители" />
            </div>
        </div>
        <div class="kpi-footer">
            <a class="kpi-link" asp-controller="AdminRoles" asp-action="Index">
                <span class="eye">👁️</span> Преглед
            </a>
        </div>
    </div>

</div>