@model List<Bevera.Models.Review>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Ревюта";
}

<div class="container-fluid p-3">
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-0">
            <div class="p-3 border-bottom d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div>
                    <h1 class="h4 mb-1">Ревюта от клиенти</h1>
                    <div class="text-muted small">Общо ревюта: <strong>@Model.Count</strong></div>
                </div>
            </div>

            @if (!Model.Any())
            {
                <div class="p-4 text-muted">Все още няма изпратени ревюта.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Продукт</th>
                                <th>Клиент</th>
                                <th>Оценка</th>
                                <th>Коментар</th>
                                <th>Дата</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in Model)
                            {
                                <tr>
                                    <td class="fw-semibold">@(r.Product?.Name ?? $"Продукт #{r.ProductId}")</td>
                                    <td>@(r.User?.Email ?? "Потребител")</td>
                                    <td>
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            if (i <= r.Rating)
                                            {
                                                <i class="bi bi-star-fill text-warning"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-star text-warning"></i>
                                            }
                                        }
                                    </td>
                                    <td>@(string.IsNullOrWhiteSpace(r.Comment) ? "—" : r.Comment)</td>
                                    <td>@r.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
