@model Bevera.Models.ViewModels.ClientProfileViewModel
@{
    ViewData["Title"] = "Профил";
}

<style>
    .profile-title {
        font-family: 'Playfair Display', serif;
        font-size: 2rem;
    }

    .profile-card {
        border-radius: 22px;
    }

    .profile-left {
        background: linear-gradient(180deg, rgba(161,147,126,.18), rgba(0,0,0,0));
    }

    .profile-avatar {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: rgba(0,0,0,.04);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .muted-label {
        color: rgba(0,0,0,.55);
        font-size: .92rem;
    }

    .tab-content .row > div {
        padding-top: .25rem;
        padding-bottom: .25rem;
    }

    .badge-soft {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        padding: .35rem .65rem;
        border-radius: 999px;
        background: rgba(0,0,0,.04);
        font-size: .85rem;
    }
</style>

<div class="container py-4">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
        <h2 class="profile-title mb-0">Профил</h2>
        <span class="badge-soft">
            <i class="bi bi-calendar2-check"></i>
            Регистрация: @Model.CreatedAt.ToString("dd.MM.yyyy")
        </span>
    </div>

    <div class="card profile-card border-0 shadow-sm overflow-hidden">
        <div class="row g-0">

            <!-- LEFT -->
            <div class="col-md-4 p-4 border-end profile-left">
                <div class="d-flex align-items-center gap-3">
                    <div class="profile-avatar">
                        <i class="bi bi-person" style="font-size:2rem;"></i>
                    </div>
                    <div>
                        <div class="fw-bold">@Model.FirstName @Model.LastName</div>
                        <div class="text-muted">@Model.Email</div>
                    </div>
                </div>

                <a class="btn btn-warning mt-3 rounded-pill fw-semibold w-100"
                       asp-controller="Client" asp-action="EditProfile">
                    <i class="bi bi-pencil-square me-1"></i> Редакция на данните
                </a>

                <div class="mt-3 small text-muted">
                    Тук виждаш основните си данни и историята на поръчките.
                </div>
            </div>

            <!-- RIGHT -->
            <div class="col-md-8 p-4">
                <ul class="nav nav-tabs" id="profileTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="basic-tab"
                                data-bs-toggle="tab" data-bs-target="#basic"
                                type="button" role="tab">
                            <i class="bi bi-person-lines-fill me-1"></i> Основна информация
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="orders-tab"
                                data-bs-toggle="tab" data-bs-target="#orders"
                                type="button" role="tab">
                            <i class="bi bi-bag-check me-1"></i> История на поръчките
                        </button>
                    </li>
                </ul>

                <div class="tab-content pt-3">
                    <!-- BASIC -->
                    <div class="tab-pane fade show active" id="basic" role="tabpanel">
                        <div class="row">
                            <div class="col-sm-4 muted-label">Име</div>
                            <div class="col-sm-8 fw-semibold">@Model.FirstName</div>

                            <div class="col-sm-4 muted-label mt-2">Фамилия</div>
                            <div class="col-sm-8 mt-2">@Model.LastName</div>

                            <div class="col-sm-4 muted-label mt-2">Имейл</div>
                            <div class="col-sm-8 mt-2">@Model.Email</div>

                            <div class="col-sm-4 muted-label mt-2">Телефон</div>
                            <div class="col-sm-8 mt-2">@Model.PhoneNumber</div>

                            <div class="col-sm-4 muted-label mt-2">Адрес</div>
                            <div class="col-sm-8 mt-2">@Model.Address</div>
                        </div>
                    </div>

                    <!-- ORDERS -->
                    <div class="tab-pane fade" id="orders" role="tabpanel">
                        @if (Model.Orders == null || !Model.Orders.Any())
                        {
                            <div class="text-muted">Все още нямаш поръчки.</div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table align-middle">
                                    <thead>
                                        <tr>
                                            <th>Поръчка №</th>
                                            <th>Дата</th>
                                            <th>Общо</th>
                                            <th>Статус</th>
                                            <th class="text-end">Действия</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var o in Model.Orders)
                                        {
                                            <tr>
                                                <td class="fw-semibold">#@o.OrderId</td>
                                                <td>@o.CreatedAt.ToString("dd.MM.yyyy")</td>
                                                <td>@o.Total.ToString("0.00") €</td>
                                                <td>
                                                    <partial name="_OrderStatusBadge" model="o.Status" />
                                                </td>
                                                <td class="text-end">
                                                    <a class="btn btn-outline-primary btn-sm me-1"
                                                           asp-controller="Client"
                                                           asp-action="OrderDetails"
                                                           asp-route-id="@o.OrderId">
                                                        <i class="bi bi-eye me-1"></i> Детайли
                                                    </a>

                                                    <a class="btn btn-outline-dark btn-sm me-1"
                                                           asp-controller="Client"
                                                           asp-action="DownloadInvoice"
                                                           asp-route-id="@o.OrderId">
                                                        <i class="bi bi-receipt-cutoff me-1"></i> Фактура
                                                    </a>

                                                    @if (o.Status == "Delivered")
                                                    {
                                                        <form asp-controller="Client" asp-action="ConfirmReceived" method="post" class="d-inline">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="id" value="@o.OrderId" />
                                                            <button type="submit" class="btn btn-outline-success btn-sm">
                                                                <i class="bi bi-house-check me-1"></i> Потвърди получаване
                                                            </button>
                                                        </form>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted small">—</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>

                            <div class="text-muted small mt-2">
                                * “Потвърди получаване” се появява след като поръчката е доставена.
                            </div>
                        }
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>