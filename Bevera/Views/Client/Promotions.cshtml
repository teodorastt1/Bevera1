@model List<Bevera.Models.Catalog.Product>

@{
    ViewData["Title"] = "Промоции";

    string q = ViewBag.Q as string ?? "";
    decimal? minPrice = ViewBag.MinPrice as decimal?;
    decimal? maxPrice = ViewBag.MaxPrice as decimal?;
    bool onlyAvailable = ViewBag.OnlyAvailable != null && (bool)ViewBag.OnlyAvailable;

    int? brandId = ViewBag.BrandId as int?;
    int? categoryId = ViewBag.CategoryId as int?;
    int? minMl = ViewBag.MinMl as int?;
    int? maxMl = ViewBag.MaxMl as int?;
    string packageType = ViewBag.PackageType as string ?? "";
    string sort = ViewBag.Sort as string ?? "";

    var brands = ViewBag.Brands as List<Bevera.Models.Catalog.Brand> ?? new();
    var categories = ViewBag.Categories as List<Bevera.Models.Catalog.Category> ?? new();
    var packageTypes = ViewBag.PackageTypes as List<string> ?? new();

    var favIds = ViewBag.FavIds as List<int> ?? new();
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

<div class="promo-page-wrap py-4 py-lg-5">
    <div class="container-fluid px-3 px-lg-4">
        <div class="promo-hero mb-4 mb-lg-5">
            <div>
                <h1 class="promo-page-title mb-2">Промоции</h1>
                <div class="promo-page-subtitle">Всички активни продукти с намаление в стила на Питиетата.</div>
            </div>
        </div>

        <div class="row g-4">
            <!-- FILTERS -->
            <aside class="col-12 col-xl-3">
                <div class="filter-box">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <div class="filter-title">Филтри</div>

                        <a class="btn clear-filter-btn"
                               asp-controller="Client"
                               asp-action="Promotions">
                            Изчисти
                        </a>
                    </div>

                    <form method="get" asp-controller="Client" asp-action="Promotions">
                        <div class="mb-3">
                            <label class="form-label filter-label">Търси</label>
                            <input class="form-control filter-input" name="q" value="@q" placeholder="Напр. Coca Cola" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label filter-label">Цена (€)</label>
                            <div class="row g-2">
                                <div class="col-6">
                                    <input class="form-control filter-input"
                                           type="number"
                                           step="0.01"
                                           min="0"
                                           name="minPrice"
                                           value="@(minPrice?.ToString() ?? "")"
                                           placeholder="От" />
                                </div>
                                <div class="col-6">
                                    <input class="form-control filter-input"
                                           type="number"
                                           step="0.01"
                                           min="0"
                                           name="maxPrice"
                                           value="@(maxPrice?.ToString() ?? "")"
                                           placeholder="До" />
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label filter-label">Марка</label>
                            <select class="form-select filter-input" name="brandId">
                                <option value="">Всички</option>
                                @foreach (var brand in brands)
                                {
                                    @if (brandId == brand.Id)
                                    {
                                        <option value="@brand.Id" selected>@brand.Name</option>
                                    }
                                    else
                                    {
                                        <option value="@brand.Id">@brand.Name</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label filter-label">Категория</label>
                            <select class="form-select filter-input" name="categoryId">
                                <option value="">Всички</option>
                                @foreach (var category in categories)
                                {
                                    @if (categoryId == category.Id)
                                    {
                                        <option value="@category.Id" selected>@category.Name</option>
                                    }
                                    else
                                    {
                                        <option value="@category.Id">@category.Name</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label filter-label">Милилитри</label>
                            <div class="row g-2">
                                <div class="col-6">
                                    <input class="form-control filter-input"
                                           type="number"
                                           min="0"
                                           name="minMl"
                                           value="@(minMl?.ToString() ?? "")"
                                           placeholder="От мл" />
                                </div>
                                <div class="col-6">
                                    <input class="form-control filter-input"
                                           type="number"
                                           min="0"
                                           name="maxMl"
                                           value="@(maxMl?.ToString() ?? "")"
                                           placeholder="До мл" />
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label filter-label">Опаковка</label>
                            <select class="form-select filter-input" name="packageType">
                                <option value="">Всички</option>
                                @foreach (var type in packageTypes)
                                {
                                    @if (packageType == type)
                                    {
                                        <option value="@type" selected>@type</option>
                                    }
                                    else
                                    {
                                        <option value="@type">@type</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label filter-label">Сортиране</label>
                            <select class="form-select filter-input" name="sort">
                                @if (sort == "")
                                {
                                    <option value="" selected>Име (А-Я)</option>
                                }
                                else
                                {
                                    <option value="">Име (А-Я)</option>
                                }

                                @if (sort == "name_desc")
                                {
                                    <option value="name_desc" selected>Име (Я-А)</option>
                                }
                                else
                                {
                                    <option value="name_desc">Име (Я-А)</option>
                                }

                                @if (sort == "price_asc")
                                {
                                    <option value="price_asc" selected>Цена ↑</option>
                                }
                                else
                                {
                                    <option value="price_asc">Цена ↑</option>
                                }

                                @if (sort == "price_desc")
                                {
                                    <option value="price_desc" selected>Цена ↓</option>
                                }
                                else
                                {
                                    <option value="price_desc">Цена ↓</option>
                                }

                                @if (sort == "promo_desc")
                                {
                                    <option value="promo_desc" selected>Най-голяма промоция</option>
                                }
                                else
                                {
                                    <option value="promo_desc">Най-голяма промоция</option>
                                }

                                @if (sort == "ml_asc")
                                {
                                    <option value="ml_asc" selected>Милилитри ↑</option>
                                }
                                else
                                {
                                    <option value="ml_asc">Милилитри ↑</option>
                                }

                                @if (sort == "ml_desc")
                                {
                                    <option value="ml_desc" selected>Милилитри ↓</option>
                                }
                                else
                                {
                                    <option value="ml_desc">Милилитри ↓</option>
                                }

                                @if (sort == "end_asc")
                                {
                                    <option value="end_asc" selected>Изтичат най-скоро</option>
                                }
                                else
                                {
                                    <option value="end_asc">Изтичат най-скоро</option>
                                }
                            </select>
                        </div>

                        <div class="form-check promo-check mb-3">
                            <input class="form-check-input" type="checkbox" name="onlyAvailable" value="true" @(onlyAvailable ? "checked" : "") />
                            <label class="form-check-label">Само налични</label>
                        </div>

                        <button class="btn apply-filter-btn w-100" type="submit">
                            Приложи
                        </button>
                    </form>
                </div>
            </aside>

            <!-- PRODUCTS -->
            <section class="col-12 col-xl-9">
                @if (!Model.Any())
                {
                    <div class="alert empty-promo-alert">
                        В момента няма активни промоции по тези филтри.
                    </div>
                }
                else
                {
                    <div class="row g-4">
                        @foreach (var p in Model)
                        {
                            var img = p.Images?.FirstOrDefault(i => i.IsMain)?.ImagePath
                                      ?? p.Images?.FirstOrDefault()?.ImagePath
                                      ?? "/images/image-1.jpg";

                            bool isFav = favIds.Contains(p.Id);
                            var endDate = p.DiscountEndsAt?.ToString("yyyy-MM-ddTHH:mm:ss");
                            var available = (p.Quantity > 0 ? p.Quantity : p.StockQty);

                            <div class="col-12 col-sm-6 col-lg-4">
                                <div class="promo-product-card">
                                    <a class="promo-card-link"
                                           asp-controller="Client"
                                           asp-action="Product"
                                           asp-route-id="@p.Id">

                                        <div class="promo-product-img-wrap">
                                            <img src="@img" alt="@p.Name" class="promo-product-img" />

                                            <span class="promo-badge-small">-@p.DiscountPercent?.ToString("0")%</span>

                                            @if (User.IsInRole("Client") && available > 0 && available < 10)
                                            {
                                                <span class="low-stock-badge">Ниска наличност</span>
                                            }

                                            @if (p.DiscountEndsAt.HasValue)
                                            {
                                                <div class="promo-timer promo-timer-card" data-discount-end="@endDate">
                                                    До края: <span>--:--</span>
                                                </div>
                                            }
                                        </div>

                                        <div class="promo-product-body">
                                            <div class="promo-product-name">@p.Name</div>

                                            @if (p.Brand != null)
                                            {
                                                <div class="promo-product-meta">@p.Brand.Name</div>
                                            }

                                            <div class="promo-product-meta">
                                                @(decimal.Round(p.VolumeLiters * 1000m, 0)) мл
                                                @if (!string.IsNullOrWhiteSpace(p.PackageType))
                                                {
                                                    <text> • @p.PackageType</text>
                                                }
                                            </div>

                                            <div class="promo-product-price">
                                                <span class="old-price">@p.Price.ToString("0.00") €</span>
                                                <span class="new-price">@p.EffectivePrice.ToString("0.00") €</span>
                                            </div>
                                        </div>
                                    </a>

                                    <div class="promo-card-actions">
                                        @if (User.Identity?.IsAuthenticated == true)
                                        {
                                            <form asp-controller="Cart" asp-action="Add" method="post" class="flex-fill">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="productId" value="@p.Id" />
                                                <input type="hidden" name="qty" value="1" />
                                                <input type="hidden" name="returnUrl" value="@returnUrl" />
                                                <button type="submit" class="btn buy-btn w-100">
                                                    Купи
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <a class="btn buy-btn w-100 flex-fill"
                                                   asp-area="Identity"
                                                   asp-page="/Account/Login"
                                                   asp-route-returnUrl="@returnUrl">
                                                Купи
                                            </a>
                                        }

                                        @if (User.Identity?.IsAuthenticated == true)
                                        {
                                            <form asp-controller="Client" asp-action="ToggleFavorite" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="productId" value="@p.Id" />
                                                <input type="hidden" name="returnUrl" value="@returnUrl" />
                                                <button type="submit"
                                                        class="btn fav-btn @(isFav ? "active" : "")"
                                                        title="Любими">
                                                    <i class="bi @(isFav ? "bi-heart-fill" : "bi-heart")"></i>
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <a class="btn fav-btn"
                                                   asp-area="Identity"
                                                   asp-page="/Account/Login"
                                                   asp-route-returnUrl="@returnUrl"
                                                   title="Любими">
                                                <i class="bi bi-heart"></i>
                                            </a>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </section>
        </div>
    </div>
</div>

<style>
    .promo-page-wrap {
        background: linear-gradient(180deg, #fffdf9 0%, #fffaf4 40%, #fffefa 100%);
        min-height: 100vh;
    }

    .promo-hero {
        background: linear-gradient(135deg, rgba(255,255,255,.88), rgba(255,248,239,.96));
        border: 1px solid rgba(230, 220, 210, .85);
        border-radius: 30px;
        padding: 28px 30px;
        box-shadow: 0 16px 40px rgba(76, 52, 32, .06);
    }

    .promo-page-title {
        font-family: 'Playfair Display', serif;
        font-weight: 800;
        font-size: 3rem;
        color: #202431;
        line-height: 1.1;
        margin: 0;
    }

    .promo-page-subtitle {
        color: #7c8492;
        font-size: 1.08rem;
    }

    .filter-box {
        background: linear-gradient(180deg, rgba(255,255,255,.88), rgba(255,250,244,.96));
        border: 1px solid rgba(230, 220, 210, .85);
        border-radius: 28px;
        padding: 22px;
        position: sticky;
        top: 92px;
        box-shadow: 0 16px 40px rgba(76, 52, 32, .06);
    }

    .filter-title {
        font-weight: 800;
        letter-spacing: .04em;
        text-transform: uppercase;
        font-size: .92rem;
        color: #222733;
    }

    .filter-label {
        font-size: .82rem;
        color: #7c8492;
        font-weight: 700;
        margin-bottom: 6px;
    }

    .filter-input {
        border-radius: 16px;
        border: 1px solid rgba(226, 214, 203, .95);
        background: #fffdfa;
        min-height: 46px;
        box-shadow: none !important;
    }

        .filter-input:focus {
            border-color: rgba(245,179,1,.55);
            box-shadow: 0 0 0 .18rem rgba(245,179,1,.14) !important;
            background: #fff;
        }

    .promo-check .form-check-input:checked {
        background-color: #f5b301;
        border-color: #f5b301;
    }

    .apply-filter-btn {
        background: linear-gradient(135deg, #1f2430, #2e3645);
        color: #fff;
        border: 0;
        border-radius: 999px;
        padding: .85rem 1.2rem;
        font-weight: 800;
        box-shadow: 0 12px 24px rgba(31, 36, 48, .18);
    }

        .apply-filter-btn:hover {
            background: linear-gradient(135deg, #161a23, #252d3a);
            color: #fff;
        }

    .clear-filter-btn {
        border-radius: 999px;
        border: 1px solid rgba(210, 200, 190, .95);
        background: #fff;
        color: #273040;
        font-weight: 700;
        padding: .45rem .9rem;
    }

        .clear-filter-btn:hover {
            background: #fff8ef;
            color: #1f2430;
        }

    .empty-promo-alert {
        background: linear-gradient(180deg, rgba(255,255,255,.88), rgba(255,250,244,.96));
        border: 1px solid rgba(230, 220, 210, .85);
        border-radius: 24px;
        padding: 18px 20px;
        color: #5e6675;
        box-shadow: 0 16px 40px rgba(76, 52, 32, .06);
    }

    .promo-product-card {
        display: flex;
        flex-direction: column;
        height: 100%;
        background: #fff;
        border: 1px solid rgba(235, 225, 216, .95);
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 12px 30px rgba(40, 32, 24, .08);
        transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
    }

        .promo-product-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 18px 36px rgba(40, 32, 24, .14);
            border-color: rgba(245,179,1,.35);
        }

    .promo-card-link {
        display: block;
        text-decoration: none;
        color: inherit;
    }

    .promo-product-img-wrap {
        height: 240px;
        background: linear-gradient(180deg, #fffdfa 0%, #fff7ee 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 18px;
        overflow: hidden;
        position: relative;
        border-bottom: 1px solid rgba(238,230,220,.75);
    }

    .promo-product-img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        display: block;
        transition: transform .22s ease;
    }

    .promo-product-card:hover .promo-product-img {
        transform: scale(1.04);
    }

    .promo-product-body {
        padding: 16px 16px 10px;
    }

    .promo-product-name {
        color: #141821;
        font-size: 1rem;
        font-weight: 800;
        line-height: 1.45;
        min-height: 46px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .promo-product-meta {
        font-size: .86rem;
        color: #7b8492;
        margin-top: 4px;
    }

    .promo-product-price {
        margin-top: 10px;
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
    }

    .old-price {
        text-decoration: line-through;
        color: #8e8e8e;
        font-weight: 600;
    }

    .new-price {
        color: #AD0B16;
        font-weight: 900;
        font-size: 1.08rem;
    }

    .promo-card-actions {
        padding: 0 16px 16px;
        display: flex;
        gap: 10px;
        margin-top: auto;
    }

    .buy-btn {
        background: linear-gradient(135deg, #1f2430, #2e3645);
        color: #fff;
        border: 0;
        border-radius: 999px;
        padding: .78rem 1rem;
        font-weight: 800;
    }

        .buy-btn:hover {
            background: linear-gradient(135deg, #161a23, #252d3a);
            color: #fff;
        }

    .fav-btn {
        min-width: 48px;
        height: 48px;
        border-radius: 999px;
        border: 1px solid rgba(220, 53, 69, .24);
        color: #dc3545;
        background: #fff;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

        .fav-btn:hover {
            background: #fff5f6;
            color: #c62839;
        }

        .fav-btn.active {
            background: #dc3545;
            color: #fff;
            border-color: #dc3545;
        }

    .promo-badge-small {
        position: absolute;
        top: 12px;
        right: 12px;
        z-index: 2;
        padding: 7px 11px;
        font-size: .78rem;
        font-weight: 900;
        letter-spacing: .06em;
        border-radius: 12px;
        background: linear-gradient(135deg, #cf1d2d, #a40f19);
        color: #fff;
        box-shadow: 0 10px 22px rgba(173,11,22,.22);
    }

    .low-stock-badge {
        position: absolute;
        top: 12px;
        left: 12px;
        z-index: 2;
        padding: 7px 11px;
        font-size: .76rem;
        font-weight: 900;
        letter-spacing: .03em;
        border-radius: 12px;
        background: linear-gradient(135deg, #ffc928, #f5b301);
        color: #111;
        box-shadow: 0 10px 22px rgba(245,179,1,.24);
    }

    .promo-timer-card {
        position: absolute;
        left: 10px;
        right: 10px;
        bottom: 10px;
        z-index: 2;
        background: rgba(17,17,17,.82);
        color: #fff;
        border-radius: 12px;
        padding: 7px 10px;
        font-size: .8rem;
        font-weight: 700;
        text-align: center;
        backdrop-filter: blur(6px);
    }

    @@media (max-width: 1199px) {
        .filter-box {
            position: static;
        }
    }

    @@media (max-width: 991px) {
        .promo-page-title {
            font-size: 2.4rem;
        }

        .promo-hero,
        .filter-box {
            border-radius: 24px;
        }

        .promo-product-img-wrap {
            height: 220px;
        }
    }

    @@media (max-width: 575px) {
        .promo-product-img-wrap {
            height: 210px;
        }

        .promo-card-actions {
            gap: 8px;
        }
    }
</style>