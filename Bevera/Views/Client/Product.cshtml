@model Bevera.Models.Catalog.Product

@{
    ViewData["Title"] = Model.Name;

    var available = Model.StockQty;
    var isOutOfStock = available <= 0;
    var isLowStock = available > 0 && available <= Model.LowStockThreshold;
    var isInStock = available > Model.LowStockThreshold;

    var imageSrc =
        Model.Images?.FirstOrDefault(i => i.IsMain)?.ImagePath
        ?? Model.Images?.FirstOrDefault()?.ImagePath
        ?? Url.Content("~/images/image-1.jpg");
}

<div class="product-page-wrap py-4 py-lg-5">
    <div class="container">
        <div class="product-shell">
            <div class="row g-0">
                <div class="col-lg-6">
                    <div class="product-image-panel @(isOutOfStock ? "product-image-panel-out" : "")">
                        <img src="@imageSrc" alt="@Model.Name" class="product-main-image" />

                        @if (Model.DiscountPercent.HasValue && Model.DiscountPercent.Value > 0 &&
                                                     (!Model.DiscountEndsAt.HasValue || Model.DiscountEndsAt.Value >= DateTime.UtcNow))
                        {
                            <span class="product-discount-badge">-@Model.DiscountPercent.Value.ToString("0")%</span>
                        }

                        @if (isLowStock)
                        {
                            <span class="product-low-badge">Ниска наличност</span>
                        }

                        @if (isOutOfStock)
                        {
                            <div class="product-out-overlay">
                                <span><i class="bi bi-x-circle me-1"></i> Изчерпан продукт</span>
                            </div>
                        }
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="product-content">
                        <div class="product-top-meta">
                            @if (Model.Brand != null)
                            {
                                <span class="top-meta-pill">@Model.Brand.Name</span>
                            }

                            @if (Model.Category != null)
                            {
                                <span class="top-meta-pill soft">@Model.Category.Name</span>
                            }
                        </div>

                        <h1 class="product-title">@Model.Name</h1>

                        <div class="product-sub-meta">
                            @if (Model.Ml.HasValue && Model.Ml.Value > 0)
                            {
                                <span>@Model.Ml мл</span>
                            }
                            else if (Model.VolumeLiters > 0)
                            {
                                <span>@(decimal.Round(Model.VolumeLiters * 1000m, 0)) мл</span>
                            }

                            @if (!string.IsNullOrWhiteSpace(Model.PackageType))
                            {
                                <span>• @Model.PackageType</span>
                            }
                        </div>

                        <div class="product-price-block">
                            @if (Model.DiscountPercent.HasValue && Model.DiscountPercent.Value > 0 &&
                                                             (!Model.DiscountEndsAt.HasValue || Model.DiscountEndsAt.Value >= DateTime.UtcNow))
                            {
                                <span class="old-product-price">@Model.Price.ToString("0.00") €</span>
                                <span class="current-product-price">@Model.EffectivePrice.ToString("0.00") €</span>
                            }
                            else
                            {
                                <span class="current-product-price">@Model.Price.ToString("0.00") €</span>
                            }
                        </div>

                        <div class="stock-status-wrap">
                            @if (isOutOfStock)
                            {
                                <span class="stock-pill stock-out">
                                    <i class="bi bi-x-circle"></i>
                                    Няма наличност, очаквайте бройки
                                </span>
                            }
                            else if (isLowStock)
                            {
                                <span class="stock-pill stock-low">
                                    <i class="bi bi-exclamation-circle"></i>
                                    Ниска наличност – остават @available бр.
                                </span>
                            }
                            else
                            {
                                <span class="stock-pill stock-in">
                                    <i class="bi bi-check-circle"></i>
                                    Налично
                                </span>
                            }
                        </div>

                        @if (!string.IsNullOrWhiteSpace(Model.Description))
                        {
                            <div class="product-description-box">
                                <div class="section-mini-title">Описание</div>
                                <p class="product-description">@Model.Description</p>
                            </div>
                        }

                        <div class="product-actions">
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <form asp-controller="Client" asp-action="ToggleFavorite" method="post" class="m-0">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@Model.Id" />
                                    <input type="hidden" name="returnUrl" value="@Context.Request.Path" />

                                    <button type="submit" class="btn fav-action-btn">
                                        <i class="bi bi-heart me-1"></i> Добави в любими
                                    </button>
                                </form>
                            }
                            else
                            {
                                <a class="btn fav-action-btn"
                                       asp-area="Identity"
                                       asp-page="/Account/Login"
                                       asp-route-returnUrl="@Context.Request.Path">
                                    <i class="bi bi-heart me-1"></i> Добави в любими
                                </a>
                            }

                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <form asp-controller="Cart" asp-action="Add" method="post" class="m-0">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@Model.Id" />
                                    <input type="hidden" name="qty" value="1" />
                                    <input type="hidden" name="returnUrl" value="@Context.Request.Path" />

                                    <button type="submit"
                                            class="btn buy-action-btn @(isOutOfStock ? "buy-action-btn-disabled" : "")"
                                        @(isOutOfStock ? "disabled" : null)>
                                        <i class="bi bi-cart-plus me-1"></i> Купи
                                    </button>
                                </form>
                            }
                            else
                            {
                                @if (isOutOfStock)
                                {
                                    <a class="btn buy-action-btn buy-action-btn-disabled disabled">
                                        <i class="bi bi-cart-plus me-1"></i> Купи
                                    </a>
                                }
                                else
                                {
                                    <a class="btn buy-action-btn"
                                           asp-area="Identity"
                                           asp-page="/Account/Login"
                                           asp-route-returnUrl="@Context.Request.Path">
                                        <i class="bi bi-cart-plus me-1"></i> Купи
                                    </a>
                                }
                            }
                        </div>

                        <div class="product-note">
                            @if (isOutOfStock)
                            {
                                <text>В момента продуктът е изчерпан. Очаквайте ново зареждане.</text>
                            }
                            else if (isLowStock)
                            {
                                <text>Побързай — остават само @available бр.</text>
                            }
                            else
                            {
                                <text>Натисни „Купи“ и продуктът влиза директно в количката.</text>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="reviews-section mt-4 mt-lg-5">
            <div class="reviews-shell">
                <h3 class="reviews-title mb-3">Ревюта</h3>

                @if (Model.Reviews == null || !Model.Reviews.Any())
                {
                    <div class="empty-review-box">
                        Все още няма ревюта за този продукт.
                    </div>
                }
                else
                {
                    <div class="row g-3">
                        @foreach (var r in Model.Reviews.OrderByDescending(x => x.CreatedAt))
                        {
                            <div class="col-12">
                                <div class="review-card">
                                    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                                        <div class="fw-bold">@((r.User?.Email) ?? "Потребител")</div>
                                        <div class="review-date">@r.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")</div>
                                    </div>

                                    <div class="mt-2">
                                        @{
                                            for (int i = 1; i <= 5; i++)
                                            {
                                                if (i <= r.Rating)
                                                {
                                                    <i class="bi bi-star-fill text-warning"></i>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-star text-warning"></i>
                                                }
                                            }
                                        }
                                    </div>

                                    @if (!string.IsNullOrWhiteSpace(r.Comment))
                                    {
                                        <div class="review-comment mt-2">@r.Comment</div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }

                @if ((bool)(ViewBag.CanReview ?? false))
                {
                    <div class="review-form-card mt-4">
                        <h5 class="mb-3">Остави ревю</h5>

                        <form asp-controller="Reviews" asp-action="Create" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productId" value="@Model.Id" />

                            <div class="mb-3">
                                <label class="form-label review-label">Оценка</label>
                                <select name="rating" class="form-select review-input">
                                    <option value="5">⭐⭐⭐⭐⭐</option>
                                    <option value="4">⭐⭐⭐⭐</option>
                                    <option value="3">⭐⭐⭐</option>
                                    <option value="2">⭐⭐</option>
                                    <option value="1">⭐</option>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label review-label">Коментар</label>
                                <textarea name="comment" class="form-control review-input" rows="4"
                                          placeholder="Напиши мнение за продукта..."></textarea>
                            </div>

                            <button class="btn submit-review-btn">Изпрати ревю</button>
                        </form>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .product-page-wrap {
        background: linear-gradient(180deg, #fffdf9 0%, #fffaf4 40%, #fffefa 100%);
        min-height: 100vh;
    }

    .product-shell {
        background: #fff;
        border: 1px solid rgba(235, 225, 216, .95);
        border-radius: 28px;
        overflow: hidden;
        box-shadow: 0 16px 40px rgba(76, 52, 32, .08);
    }

    .product-image-panel {
        height: 100%;
        min-height: 520px;
        background: linear-gradient(180deg, #fffdfa 0%, #fff7ee 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 28px;
        position: relative;
        border-right: 1px solid rgba(238,230,220,.75);
    }

    .product-main-image {
        width: 100%;
        max-height: 430px;
        object-fit: contain;
        display: block;
        transition: transform .22s ease;
    }

    .product-image-panel:hover .product-main-image {
        transform: scale(1.03);
    }

    .product-image-panel-out .product-main-image {
        filter: grayscale(100%) opacity(.62);
    }

    .product-out-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        pointer-events: none;
    }

        .product-out-overlay span {
            background: rgba(25,25,25,.74);
            color: #fff;
            padding: .8rem 1.2rem;
            border-radius: 999px;
            font-weight: 800;
            box-shadow: 0 10px 24px rgba(0,0,0,.18);
        }

    .product-discount-badge {
        position: absolute;
        top: 16px;
        right: 16px;
        z-index: 2;
        padding: 8px 12px;
        font-size: .82rem;
        font-weight: 900;
        letter-spacing: .05em;
        border-radius: 12px;
        background: linear-gradient(135deg, #cf1d2d, #a40f19);
        color: #fff;
        box-shadow: 0 10px 22px rgba(173,11,22,.22);
    }

    .product-low-badge {
        position: absolute;
        top: 16px;
        left: 16px;
        z-index: 2;
        padding: 8px 12px;
        font-size: .8rem;
        font-weight: 900;
        letter-spacing: .03em;
        border-radius: 12px;
        background: linear-gradient(135deg, #ffc928, #f5b301);
        color: #111;
        box-shadow: 0 10px 22px rgba(245,179,1,.24);
    }

    .product-content {
        padding: 28px 28px 24px;
    }

    .product-top-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 14px;
    }

    .top-meta-pill {
        display: inline-flex;
        align-items: center;
        padding: 8px 12px;
        border-radius: 999px;
        font-size: .82rem;
        font-weight: 800;
        background: linear-gradient(135deg, #1f2430, #2e3645);
        color: #fff;
    }

        .top-meta-pill.soft {
            background: #fff4e0;
            color: #8a5a00;
        }

    .product-title {
        font-family: 'Playfair Display', serif;
        font-weight: 800;
        font-size: 3rem;
        line-height: 1.08;
        color: #202431;
        margin: 0 0 10px;
    }

    .product-sub-meta {
        color: #7b8492;
        font-size: 1rem;
        margin-bottom: 16px;
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        align-items: center;
    }

    .product-price-block {
        margin-bottom: 16px;
        display: flex;
        align-items: end;
        gap: 12px;
        flex-wrap: wrap;
    }

    .old-product-price {
        text-decoration: line-through;
        color: #8e8e8e;
        font-weight: 700;
        font-size: 1.1rem;
    }

    .current-product-price {
        font-weight: 900;
        font-size: 2rem;
        color: #1d2431;
    }

    .stock-status-wrap {
        margin-bottom: 18px;
    }

    .stock-pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 9px 15px;
        border-radius: 999px;
        font-size: .94rem;
        font-weight: 800;
        border: 1px solid transparent;
    }

    .stock-in {
        background: #eaf7ee;
        color: #1f7a3d;
        border-color: #b9e2c5;
    }

    .stock-low {
        background: #fff4db;
        color: #9a6700;
        border-color: #f3d28b;
    }

    .stock-out {
        background: #fdeaea;
        color: #b42318;
        border-color: #f5b5b5;
    }

    .product-description-box {
        background: linear-gradient(180deg, rgba(255,253,250,.95), rgba(255,248,239,.96));
        border: 1px solid rgba(230, 220, 210, .8);
        border-radius: 22px;
        padding: 18px 18px 16px;
        margin-top: 12px;
    }

    .section-mini-title {
        font-weight: 800;
        color: #202431;
        margin-bottom: 8px;
    }

    .product-description {
        color: rgba(32,36,49,.88);
        margin-bottom: 0;
        line-height: 1.7;
    }

    .product-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 20px;
    }

    .fav-action-btn,
    .buy-action-btn {
        border-radius: 999px;
        padding: .82rem 1.2rem;
        font-weight: 800;
    }

    .fav-action-btn {
        border: 1px solid rgba(220, 53, 69, .24);
        color: #dc3545;
        background: #fff;
    }

        .fav-action-btn:hover {
            background: #fff5f6;
            color: #c62839;
        }

    .buy-action-btn {
        border: 0;
        background: linear-gradient(135deg, #1f2430, #2e3645);
        color: #fff;
        box-shadow: 0 12px 24px rgba(31, 36, 48, .18);
    }

        .buy-action-btn:hover {
            background: linear-gradient(135deg, #161a23, #252d3a);
            color: #fff;
        }

    .buy-action-btn-disabled,
    .buy-action-btn-disabled:hover {
        background: #9e9e9e !important;
        color: #fff !important;
        box-shadow: none !important;
        cursor: not-allowed !important;
    }

    .product-note {
        margin-top: 14px;
        color: rgba(32,36,49,.58);
        font-size: .95rem;
    }

    .reviews-shell {
        background: linear-gradient(180deg, rgba(255,255,255,.88), rgba(255,250,244,.96));
        border: 1px solid rgba(230, 220, 210, .85);
        border-radius: 28px;
        padding: 24px;
        box-shadow: 0 16px 40px rgba(76, 52, 32, .06);
    }

    .reviews-title {
        font-family: 'Playfair Display', serif;
        font-weight: 800;
        font-size: 2.2rem;
        color: #202431;
    }

    .empty-review-box {
        background: #fff;
        border: 1px solid rgba(235, 225, 216, .95);
        border-radius: 18px;
        padding: 16px 18px;
        color: #6a7380;
    }

    .review-card {
        background: #fff;
        border: 1px solid rgba(235, 225, 216, .95);
        border-radius: 20px;
        padding: 16px 18px;
        box-shadow: 0 10px 24px rgba(0,0,0,.05);
    }

    .review-date {
        color: #7b8492;
        font-size: .88rem;
    }

    .review-comment {
        color: rgba(32,36,49,.9);
        line-height: 1.65;
    }

    .review-form-card {
        background: #fff;
        border: 1px solid rgba(235, 225, 216, .95);
        border-radius: 22px;
        padding: 20px;
        box-shadow: 0 10px 24px rgba(0,0,0,.05);
    }

    .review-label {
        font-size: .84rem;
        color: #7c8492;
        font-weight: 700;
        margin-bottom: 6px;
    }

    .review-input {
        border-radius: 16px;
        border: 1px solid rgba(226, 214, 203, .95);
        background: #fffdfa;
        min-height: 46px;
        box-shadow: none !important;
    }

        .review-input:focus {
            border-color: rgba(245,179,1,.55);
            box-shadow: 0 0 0 .18rem rgba(245,179,1,.14) !important;
            background: #fff;
        }

    .submit-review-btn {
        background: linear-gradient(135deg, #1f2430, #2e3645);
        color: #fff;
        border: 0;
        border-radius: 999px;
        padding: .82rem 1.2rem;
        font-weight: 800;
        box-shadow: 0 12px 24px rgba(31, 36, 48, .18);
    }

        .submit-review-btn:hover {
            background: linear-gradient(135deg, #161a23, #252d3a);
            color: #fff;
        }

    @@media (max-width: 991px) {
        .product-image-panel {
            min-height: 360px;
            border-right: 0;
            border-bottom: 1px solid rgba(238,230,220,.75);
        }

        .product-content {
            padding: 22px 18px 20px;
        }

        .product-title {
            font-size: 2.3rem;
        }

        .current-product-price {
            font-size: 1.7rem;
        }

        .reviews-title {
            font-size: 1.9rem;
        }

        .reviews-shell,
        .product-shell {
            border-radius: 22px;
        }
    }

    @@media (max-width: 575px) {
        .product-actions {
            flex-direction: column;
        }

        .fav-action-btn,
        .buy-action-btn {
            width: 100%;
        }

        .product-main-image {
            max-height: 300px;
        }
    }
</style>