@using Microsoft.AspNetCore.Identity
@using Bevera.Data
@using Bevera.Models

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject ApplicationDbContext Db

@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    var adminId = UserManager.GetUserId(User);
    var adminUser = !string.IsNullOrEmpty(adminId)
        ? Db.Users.FirstOrDefault(x => x.Id == adminId)
        : null;

    var adminLabel = adminUser?.Email ?? (User.Identity?.Name ?? "Администратор");

    var adminUnreadCount = !string.IsNullOrEmpty(adminId)
        ? Db.AppNotifications.Count(x => x.UserId == adminId && !x.IsRead)
        : 0;

    bool IsCurrent(string controller, string? action = null)
    {
        if (string.IsNullOrWhiteSpace(action))
            return currentController == controller;

        return currentController == controller && currentAction == action;
    }
}

<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Bevera Админ</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>

<body class="admin-body">
    <div class="admin-shell">

        <aside class="admin-sidebar">
            <div class="admin-brand">Bevera</div>
            <div class="admin-sub">Административен панел</div>

            <nav class="admin-nav">
                <a asp-controller="Admin"
                       asp-action="Index"
                       class="@(IsCurrent("Admin") ? "active" : "")">
                    <span>🏠</span> Табло
                </a>

                <div class="mt-3 mb-2" style="opacity:.7;font-size:12px;">Каталог</div>

                <a asp-controller="AdminCategories"
                       asp-action="Index"
                       class="@(IsCurrent("AdminCategories") ? "active" : "")">
                    <span>🧾</span> Категории
                </a>

                <a asp-controller="AdminProducts"
                       asp-action="Index"
                       class="@(IsCurrent("AdminProducts") ? "active" : "")">
                    <span>🥤</span> Продукти
                </a>

                <a asp-controller="AdminPromotions"
                       asp-action="Index"
                       class="@(IsCurrent("AdminPromotions") ? "active" : "")">
                    <span>🔥</span> Промоции
                </a>

                <div class="mt-3 mb-2" style="opacity:.7;font-size:12px;">Поръчки и клиенти</div>

                <a asp-controller="Orders"
                       asp-action="Index"
                       class="@(IsCurrent("Orders") ? "active" : "")">
                    <span>📦</span> Поръчки
                </a>

                <a asp-controller="Reviews"
                       asp-action="Index"
                       class="@(IsCurrent("Reviews") ? "active" : "")">
                    <span>⭐</span> Ревюта
                </a>

                <div class="mt-3 mb-2" style="opacity:.7;font-size:12px;">Доставки и финанси</div>

                <a asp-controller="AdminSupply"
                       asp-action="Index"
                       class="@(IsCurrent("AdminSupply", "Index") ? "active" : "")">
                    <span>📊</span> Supply табло
                </a>

                <a asp-controller="AdminSupply"
                       asp-action="Distributors"
                       class="@(IsCurrent("AdminSupply", "Distributors") || IsCurrent("AdminSupply", "CreateDistributor") || IsCurrent("AdminSupply", "EditDistributor") || IsCurrent("AdminSupply", "DistributorProducts") || IsCurrent("AdminSupply", "AddDistributorProduct") ? "active" : "")">
                    <span>🚚</span> Дистрибутори
                </a>

                <a asp-controller="AdminSupply"
                       asp-action="PurchaseOrders"
                       class="@(IsCurrent("AdminSupply", "PurchaseOrders") || IsCurrent("AdminSupply", "CreatePurchaseOrder") || IsCurrent("AdminSupply", "PurchaseOrderDetails") || IsCurrent("AdminSupply", "AddPurchaseOrderItem") ? "active" : "")">
                    <span>🧾</span> Заявки към доставчици
                </a>

                <a asp-controller="AdminSupply"
                       asp-action="Finance"
                       class="@(IsCurrent("AdminSupply", "Finance") ? "active" : "")">
                    <span>💰</span> Финанси
                </a>

                <div class="mt-3 mb-2" style="opacity:.7;font-size:12px;">Управление</div>

                <a asp-controller="AdminRoles"
                       asp-action="Index"
                       class="@(IsCurrent("AdminRoles") ? "active" : "")">
                    <span>👤</span> Роли и потребители
                </a>
            </nav>
        </aside>

        <main class="admin-main">
            <div class="admin-topbar">
                <div class="admin-title">@ViewData["Title"]</div>

                <div class="admin-user d-flex align-items-center gap-3">
                    <div class="text-end">
                        <div class="small text-muted" style="font-weight:700;">Здравей, администратор</div>
                        <div style="font-weight:700;">@adminLabel</div>
                    </div>

                    <a asp-controller="Notifications"
                           asp-action="Index"
                           class="position-relative text-dark text-decoration-none"
                           title="Нотификации">
                        <i class="bi bi-bell" style="font-size:1.2rem;"></i>

                        @if (adminUnreadCount > 0)
                        {
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                @adminUnreadCount
                            </span>
                        }
                    </a>

                    <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="d-inline">
                        <button class="btn btn-sm btn-outline-secondary" type="submit">Изход</button>
                    </form>
                </div>
            </div>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Затвори"></button>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Затвори"></button>
                </div>
            }

            @RenderBody()
        </main>

    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>