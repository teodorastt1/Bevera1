@using Bevera.Data
@using Bevera.Models
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject ApplicationDbContext Db

<ul class="navbar-nav align-items-center gap-2">
    @if (SignInManager.IsSignedIn(User))
    {
        var userId = UserManager.GetUserId(User);

        // ✅ Minimal DB reads: user + favorites count
        var u = Db.Users.FirstOrDefault(x => x.Id == userId);
        var favCount = Db.Favorites.Count(x => x.UserId == userId);

        string hello;
        if (User.IsInRole("Admin"))
        {
            hello = "Здравей, Админ";
        }
        else if (User.IsInRole("Worker"))
        {
            hello = "Здравей, " + (u?.Email ?? "Работник");
        }
        else
        {
            var name = !string.IsNullOrWhiteSpace(u?.FirstName) ? u!.FirstName : (u?.Email ?? "Клиент");
            hello = "Здравей, " + name;
        }

        <!-- ✅ Greeting FIRST -->
        <li class="nav-item d-none d-lg-inline">
            <span class="nav-link"
                  style="text-transform:none; letter-spacing:0; color:rgba(255,255,255,.92)!important; font-weight:700;">
                @hello
            </span>
        </li>

        <!-- Cart -->
        <li class="nav-item">
            <a class="nav-link position-relative" asp-controller="Cart" asp-action="Index" title="Количка">
                <i id="cartIcon" class="bi bi-cart3"></i>
                <span id="cartBadge" class="cart-badge d-none">0</span>
            </a>
        </li>

        <!-- Profile -->
        <li class="nav-item">
            <a class="nav-link" asp-controller="Client" asp-action="Profile" title="Профил">
                <i class="bi bi-person-circle"></i>
            </a>
        </li>

        <!-- Favorites -->
        <li class="nav-item d-none d-lg-inline">
            <a class="nav-link position-relative" asp-controller="Client" asp-action="Favorites" title="Любими">
                <i class="bi bi-heart"></i>
                @if (favCount > 0)
                {
                    <span class="cart-badge"
                          style="right:-12px; top:-6px; background:#f5b301; color:#111; box-shadow:0 8px 18px rgba(245,179,1,.25)">
                        @favCount
                    </span>
                }
            </a>
        </li>

        <!-- Logout -->
        <li class="nav-item">
            <form class="d-inline" asp-area="Identity" asp-page="/Account/Logout"
                  asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button type="submit" class="btn btn-link nav-link p-0">Изход</button>
            </form>
        </li>
    }
    else
    {
        <!-- When NOT logged in: keep cart first -->
        <li class="nav-item">
            <a class="nav-link position-relative" asp-controller="Cart" asp-action="Index" title="Количка">
                <i id="cartIcon" class="bi bi-cart3"></i>
                <span id="cartBadge" class="cart-badge d-none">0</span>
            </a>
        </li>

        <li class="nav-item">
            <a class="nav-link" asp-area="Identity" asp-page="/Account/Login">Вход</a>
        </li>
        <li class="nav-item">
            <a class="nav-link bevera-login-btn" asp-area="Identity" asp-page="/Account/Register">Регистрация</a>
        </li>
    }
</ul>